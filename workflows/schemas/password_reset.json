{
  "intent": "password_reset",
  "required_fields": [
    {
      "name": "account_id",
      "type": "string",
      "prompt": "What is your account ID?",
      "validator": "account_number"
    },
    {
      "name": "verification_code",
      "type": "string",
      "prompt": "Please tell me the verification code we sent to your phone.",
      "validator": "verification_code"
    }
  ],
  "optional_fields": ["callback_number"],
  "validators": {
    "account_id": "^[0-9]{8,12}$",
    "verification_code": "^[0-9]{4,8}$"
  },
  "escalation_conditions": ["failed_verification_3x", "user_requests_human"],
  "action": "reset_password"
}
