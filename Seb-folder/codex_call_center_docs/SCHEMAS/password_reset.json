{
  "intent": "password_reset",
  "required_fields": [
    "account_id",
    "verification_code"
  ],
  "optional_fields": [
    "callback_number"
  ],
  "field_priority": [
    "account_id",
    "verification_code",
    "callback_number"
  ],
  "validators": {
    "account_id": {
      "type": "regex",
      "pattern": "^[0-9]{8,12}$"
    },
    "verification_code": {
      "type": "regex",
      "pattern": "^[0-9]{6}$"
    },
    "callback_number": {
      "type": "phone"
    }
  },
  "conditional_requirements": [],
  "action": "reset_password_tool",
  "escalation_conditions": [
    "verification_code_failed_attempts >= 3",
    "user_requests_human == true"
  ]
}