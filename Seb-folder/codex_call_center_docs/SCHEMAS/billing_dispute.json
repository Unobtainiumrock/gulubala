{
  "intent": "billing_dispute",
  "required_fields": [
    "account_number",
    "charge_date",
    "charge_amount",
    "dispute_reason"
  ],
  "optional_fields": [
    "merchant_name",
    "reference_number"
  ],
  "field_priority": [
    "account_number",
    "charge_date",
    "charge_amount",
    "dispute_reason",
    "merchant_name",
    "reference_number"
  ],
  "validators": {
    "account_number": {
      "type": "regex",
      "pattern": "^[0-9]{8,12}$"
    },
    "charge_date": {
      "type": "date"
    },
    "charge_amount": {
      "type": "currency"
    },
    "dispute_reason": {
      "type": "enum_or_text",
      "values": [
        "duplicate_charge",
        "unauthorized_charge",
        "incorrect_amount",
        "other"
      ]
    }
  },
  "conditional_requirements": [],
  "action": "open_dispute_case",
  "escalation_conditions": [
    "charge_amount > 5000",
    "fraud_indicator == true",
    "user_requests_human == true"
  ]
}