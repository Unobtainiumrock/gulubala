EIGEN_API_KEY=your-api-key-here
EIGEN_BASE_URL=https://api-web.eigenai.com/api/v1
SESSION_STORE_BACKEND=sqlite
SESSION_DB_PATH=call_center_sessions.sqlite3
SESSION_TTL_SECONDS=86400
AEROSPIKE_HOSTS=127.0.0.1:3000
AEROSPIKE_NAMESPACE=test
AEROSPIKE_SET=sessions
BLAND_API_KEY=
BLAND_WEBHOOK_URL=
BLAND_VOICE=maya
BLAND_MODEL=enhanced
BLAND_PATHWAY_ID=
BLAND_MAX_DURATION=300
# Optional: Twilio webhooks / docs (e.g. https://xxxx.ngrok-free.app)
NGROK_URL=
# Optional override for transcript links in SMS (defaults to NGROK_URL)
PUBLIC_API_BASE_URL=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_IVR_NUMBER=
TWILIO_AGENT_NUMBER=
PRESENTER_PHONE_NUMBER=

AUTH_ENABLED=false
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Cloned voice ID from Eigen (run: make clone-voice FILE=sample.wav)
# DEMO_VOICE_ID=

# python main.py --demo uses timed scripted IVR prompts by default. Set to 1 to use real STT instead.
# DEMO_LIVE_IVR=

# Scripted cancel_service demo: auto presenter call + retention bridge (default on). Set to 0 to disable.
# DEMO_FORCE_HUMAN_FLOWS=1

# Next.js dashboard (`make dashboard-dev`): WebSocket + direct fetch fallback; default http://localhost:8000. Match API_PROXY_TARGET if you change the API port.
# NEXT_PUBLIC_API_BASE=http://localhost:8000
